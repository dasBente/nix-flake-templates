[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://../result/lib/librust_godot.so"
linux.release.x86_64 =   "res://../result/lib/librust_godot.so"
windows.debug.x86_64 =   "res://../result/lib/librust_godot.so"
windows.release.x86_64 = "res://../result/lib/librust_godot.so"
